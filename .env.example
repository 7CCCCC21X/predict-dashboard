# Vercel Project Settings -> Environment Variables

# 主网必填：Predict REST API 代理使用
PREDICT_API_KEY=your_predict_fun_api_key

# 可选：覆盖 Predict REST 官方默认地址
# PREDICT_API_BASE=https://api.predict.fun
# PREDICT_TESTNET_API_BASE=https://api-testnet.predict.fun
# PREDICT_TESTNET_API_KEY=optional_testnet_key

# 可选：Predict.fun 官网 GraphQL PNL 接口
# 用于 api/portfolio-pnl.js 获取官网 Portfolio PNL
PREDICT_GRAPHQL_URL=https://graphql.predict.fun/graphql
